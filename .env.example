# .env.example, Veil
# Copy to .env and fill in. Never commit .env. Values marked SECRET must stay
# server-side only and must never be prefixed NEXT_PUBLIC_.
# Confirm RPC URL and passphrase against the loaded Stellar skill, and the
# RISC Zero / Bonsai names against dev.risczero.com, in case they have moved.

# ─── Stellar / Soroban, testnet ───
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Deployer and contract owner identity.
# Prefer the Stellar CLI keychain (stellar keys generate / use an alias) over a
# raw secret here. Only set STELLAR_SECRET_KEY if a script must sign headless.
STELLAR_ACCOUNT=G...            # public key of the deployer / owner, not secret
STELLAR_SECRET_KEY=S...         # SECRET, optional if using the CLI keychain

# ─── Deployed addresses, fill in after each deploy ───
VERIFIER_CONTRACT_ID=C...       # forked Nethermind risc0 verifier
VEIL_CONTRACT_ID=C...           # veil registry contract
GUEST_IMAGE_ID=                 # hex image id printed when the guest builds

# ─── RISC Zero proving ───
# 1 = fast fake proofs for iteration. 0 = real proofs.
# Sprint 1's on-chain test REQUIRES 0, dev-mode proofs do not verify on-chain.
RISC0_DEV_MODE=1
# Only needed if you wrap STARK to Groth16 via the Bonsai service instead of
# local Docker. Leave blank if proving the wrap locally.
BONSAI_API_KEY=                 # SECRET
BONSAI_API_URL=https://api.bonsai.xyz/

# ─── Frontend, browser-exposed, must be safe to publish ───
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
NEXT_PUBLIC_VEIL_CONTRACT_ID=C...
NEXT_PUBLIC_VERIFIER_CONTRACT_ID=C...

# ─── Optional dev convenience ───
# RUST_LOG=info
